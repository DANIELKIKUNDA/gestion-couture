NODE_ENV=production
PORT=3000

PGHOST=postgres
PGPORT=5432
PGUSER=atelier_app
PGPASSWORD=change_me
PGDATABASE=atelier_prod

CORS_ALLOWED_ORIGINS=https://app.monatelier.com
APP_DOMAIN=app.monatelier.com

AUTH_JWT_SECRET=change_me_with_a_long_random_secret_at_least_32_chars
AUTH_JWT_TTL_SECONDS=86400
AUTH_REFRESH_TTL_SECONDS=31536000
AUTH_REFRESH_COOKIE_NAME=atelier_refresh_token
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_MAX_AGE_MS=34560000000

MEDIA_STORAGE_ROOT=/app/storage
MEDIA_TEMP_ROOT=/app/storage/tmp
MEDIA_MAX_FILE_SIZE_BYTES=5242880
MEDIA_MAX_FILES_PER_COMMANDE=3
MEDIA_ORIGINAL_MAX_WIDTH=1800
MEDIA_ORIGINAL_MAX_HEIGHT=1800
MEDIA_THUMB_MAX_WIDTH=420
MEDIA_THUMB_MAX_HEIGHT=420
MEDIA_WEBP_QUALITY=82
MEDIA_THUMB_WEBP_QUALITY=74

VITE_API_BASE_URL=/api

NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
UPTIME_KUMA_PORT=3001

STORAGE_HOST_PATH=/opt/atelier_backend/storage
BACKUP_HOST_PATH=/opt/atelier_backend/backups
CERTBOT_WEBROOT_HOST_PATH=/opt/atelier_backend/deploy/certbot/www
LETSENCRYPT_ROOT_PATH=/etc/letsencrypt
